{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "UFC Panel",
  "version": "0.1.0",
  "identifier": "com.ufcpanel.desktop",
  "build": {
    "beforeDevCommand": "corepack pnpm dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "corepack pnpm build",
    "frontendDist": "../out"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "UFC Panel · Combat Intelligence",
        "width": 1440,
        "height": 900,
        "minWidth": 1100,
        "minHeight": 700,
        "center": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/**"]
      },
      "csp": "default-src 'self'; connect-src 'self' ipc: http://ipc.localhost; img-src 'self' asset: http://asset.localhost data: https:; style-src 'self' 'unsafe-inline'; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "category": "Utility",
    "shortDescription": "Local-first UFC analytics and comparison tool",
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": false
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDc2OTIwM0IzMzYyNERDNApSV1RFVFdJek95QnBCNGxqK3JaOGpiTUhRWjZTZFJEMHErSEtaS1B3WlVBRVh4eDgyMjUxcjVWTgo=",
      "endpoints": [
        "https://github.com/ademiru/UFC_Combat_Intelligence/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
